bar {
    swaybar_command waybar
}

##### CLAMPMODE #####
set $laptop eDP-1
bindswitch --reload --locked lid:on output $laptop disable
bindswitch --reload --locked lid:off output $laptop enable

mode "passthrough" {
    bindsym $mod+Shift+p mode "default"
}

bindsym $mod+Shift+p mode "passthrough"

set $nag exec swaynagmode
mode "nag" {
  bindsym {
    Ctrl+d    mode "default"

    Ctrl+c    $nag --exit
    q         $nag --exit
    Escape    $nag --exit

    Return    $nag --confirm

    Tab       $nag --select prev
    Shift+Tab $nag --select next

    Left      $nag --select next
    Right     $nag --select prev

    Up        $nag --select next
    Down      $nag --select prev
  }
}
swaynag_command swaynagmode

##### STARTUP #####
exec spice-vdagent
exec kanshi
exec dbus-update-activation-environment --systemd DISPLAY WAYLAND_DISPLAY SWAYSOCK

# Push to talk via Handy
exec handy --start-hidden
bindsym --no-repeat $mod+i exec handy --toggle-transcription
bindsym --release $mod+i exec handy --toggle-transcription

##### APP CONFIGURATION #####
for_window [app_id="taia-popup*"] floating enable

##### STANDARD WORKSPACES #####
assign [app_id=^firefox$] workspace 2
assign [app_id=^slack$] workspace 2
assign [app_id=^thunderbird-esr$] workspace 10


# Handles systemd integration
include /etc/sway/config.d/*
